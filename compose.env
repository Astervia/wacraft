# ─────────── Runtime ───────────
ENV=development # local | development | production
SU_PASSWORD=change_me_safely
JWT_SECRET=32_random_chars_min
AUTH_TOKEN=                        # optional machine-to-machine / internal webhook token

# ─────────── Registration ───────────
ALLOW_REGISTRATION=true            # set to false after your team is set up
REQUIRE_EMAIL_VERIFICATION=true    # requires SMTP config below

# ─────────── Email (SMTP) ───────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
APP_BASE_URL=http://localhost      # base URL of the frontend (used in email links)

# ─────────── Firewall ───────────
# IP_ALLOWLIST=                    # comma-separated CIDRs; empty = no restriction
# IP_DENYLIST=                     # comma-separated CIDRs; empty = no restriction
RATE_LIMIT_ENABLED=true

# ─────────── Frontend (Angular UI) ───────────
APP_TITLE="[LOCAL] wacraft"
MAIN_SERVER_URL=127.0.0.1:6900
MAIN_SERVER_SECURITY=false
GOOGLE_MAPS_API_KEY=               # optional – needed for location messages
WEBSOCKET_BASE_PING_INTERVAL=3000
# AUTOMATION_SERVER_URL=           # optional – URL of n8n or other automation server
# AUTOMATION_SERVER_SECURITY=false

# ─────────── Billing (optional) ───────────
# BILLING_ENABLED=true
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
